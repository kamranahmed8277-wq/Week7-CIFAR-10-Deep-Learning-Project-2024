# Create/update .gitignore
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.so
.Python

# Virtual Environment
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
.DS_Store

# Model Files (Large - exclude from GitHub)
*.keras
*.h5
*.pb
*.tflite
*.onnx
*.hdf5
*.ckpt
*.weights.h5

# Data files
*.npz
*.npy
*.pkl

# Model directories
BestModelweek17/
models/
checkpoints/


# Environment
.env
.env.local

# Logs
*.log
logs/

# OS files
Thumbs.db
desktop.ini

# Large archives
*.7z
*.rar
*.zip
*.tar.gz
EOF

# Add and commit .gitignore
